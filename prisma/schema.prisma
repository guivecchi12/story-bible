generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String       @id @default(cuid())
  name           String?
  email          String       @unique
  hashedPassword String
  theme          String       @default("system")
  activeBookId   String?
  activeBook     Book?        @relation("ActiveBook", fields: [activeBookId], references: [id])
  books          BookMember[]
  invitations    Invitation[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Book {
  id             String          @id @default(cuid())
  name           String
  description    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  members        BookMember[]
  invitations    Invitation[]
  characters     Character[]
  powers         Power[]
  motivations    Motivation[]
  factions       Faction[]
  locations      Location[]
  storyArcs      StoryArc[]
  plotEvents     PlotEvent[]
  timelineEvents TimelineEvent[]
  items          Item[]
  activeUsers    User[]          @relation("ActiveBook")
}

model BookMember {
  bookId    String
  userId    String
  role      String   @default("viewer")
  createdAt DateTime @default(now())
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([bookId, userId])
}

model Invitation {
  id        String    @id @default(cuid())
  email     String
  role      String    @default("viewer")
  token     String    @unique @default(cuid())
  bookId    String
  invitedBy String
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  book      Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  inviter   User      @relation(fields: [invitedBy], references: [id])
}

model Character {
  id             String                   @id @default(cuid())
  name           String
  type           String
  description    String?
  backstory      String?
  bookId         String
  factionId      String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  book           Book                     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  faction        Faction?                 @relation(fields: [factionId], references: [id])
  items          CharacterItem[]
  locations      CharacterLocation[]
  motivations    CharacterMotivation[]
  powers         CharacterPower[]
  plotEvents     PlotEventCharacter[]
  timelineEvents TimelineEventCharacter[]

  @@index([bookId])
}

model Power {
  id         String           @id @default(cuid())
  name       String
  effects    String?
  rules      String?
  weaknesses String?
  bookId     String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  book       Book             @relation(fields: [bookId], references: [id], onDelete: Cascade)
  characters CharacterPower[]

  @@index([bookId])
}

model CharacterPower {
  characterId   String
  powerId       String
  strengthLevel Int       @default(5)
  notes         String?
  isPrimary     Boolean   @default(false)
  character     Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  power         Power     @relation(fields: [powerId], references: [id], onDelete: Cascade)

  @@id([characterId, powerId])
}

model Motivation {
  id          String                @id @default(cuid())
  name        String
  description String?
  category    String
  bookId      String
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  book        Book                  @relation(fields: [bookId], references: [id], onDelete: Cascade)
  characters  CharacterMotivation[]
  factions    FactionMotivation[]

  @@index([bookId])
}

model CharacterMotivation {
  characterId   String
  motivationId  String
  priority      Int        @default(1)
  personalNotes String?
  character     Character  @relation(fields: [characterId], references: [id], onDelete: Cascade)
  motivation    Motivation @relation(fields: [motivationId], references: [id], onDelete: Cascade)

  @@id([characterId, motivationId])
}

model FactionMotivation {
  factionId    String
  motivationId String
  priority     Int        @default(1)
  notes        String?
  faction      Faction    @relation(fields: [factionId], references: [id], onDelete: Cascade)
  motivation   Motivation @relation(fields: [motivationId], references: [id], onDelete: Cascade)

  @@id([factionId, motivationId])
}

model Faction {
  id          String              @id @default(cuid())
  name        String
  description String?
  bookId      String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  book        Book                @relation(fields: [bookId], references: [id], onDelete: Cascade)
  characters  Character[]
  motivations FactionMotivation[]

  @@index([bookId])
}

model Location {
  id             String              @id @default(cuid())
  name           String
  type           String
  description    String?
  climate        String?
  culture        String?
  bookId         String
  parentId       String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  book           Book                @relation(fields: [bookId], references: [id], onDelete: Cascade)
  characters     CharacterLocation[]
  items          Item[]
  parent         Location?           @relation("LocationHierarchy", fields: [parentId], references: [id])
  children       Location[]          @relation("LocationHierarchy")
  plotEvents     PlotEvent[]
  timelineEvents TimelineEvent[]

  @@index([bookId])
}

model CharacterLocation {
  characterId String
  locationId  String
  role        String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  location    Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([characterId, locationId])
}

model StoryArc {
  id          String      @id @default(cuid())
  title       String
  description String?
  type        String
  status      String      @default("planned")
  bookId      String
  parentArcId String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  book        Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  plotEvents  PlotEvent[]
  parentArc   StoryArc?   @relation("ArcHierarchy", fields: [parentArcId], references: [id])
  subPlots    StoryArc[]  @relation("ArcHierarchy")

  @@index([bookId])
}

model PlotEvent {
  id              String               @id @default(cuid())
  title           String
  description     String?
  consequence     String?
  order           Int                  @default(0)
  bookId          String
  storyArcId      String
  locationId      String?
  timelineEventId String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  book            Book                 @relation(fields: [bookId], references: [id], onDelete: Cascade)
  location        Location?            @relation(fields: [locationId], references: [id])
  storyArc        StoryArc             @relation(fields: [storyArcId], references: [id], onDelete: Cascade)
  timelineEvent   TimelineEvent?       @relation(fields: [timelineEventId], references: [id])
  characters      PlotEventCharacter[]
  items           PlotEventItem[]

  @@index([bookId])
}

model PlotEventCharacter {
  plotEventId String
  characterId String
  role        String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  plotEvent   PlotEvent @relation(fields: [plotEventId], references: [id], onDelete: Cascade)

  @@id([plotEventId, characterId])
}

model TimelineEvent {
  id          String                   @id @default(cuid())
  title       String
  description String?
  inWorldDate String?
  era         String?
  order       Int                      @default(0)
  bookId      String
  locationId  String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  book        Book                     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  plotEvents  PlotEvent[]
  location    Location?                @relation(fields: [locationId], references: [id])
  characters  TimelineEventCharacter[]

  @@index([bookId])
}

model TimelineEventCharacter {
  timelineEventId String
  characterId     String
  notes           String?
  character       Character     @relation(fields: [characterId], references: [id], onDelete: Cascade)
  timelineEvent   TimelineEvent @relation(fields: [timelineEventId], references: [id], onDelete: Cascade)

  @@id([timelineEventId, characterId])
}

model Item {
  id          String          @id @default(cuid())
  name        String
  type        String
  description String?
  lore        String?
  properties  String?
  bookId      String
  locationId  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  book        Book            @relation(fields: [bookId], references: [id], onDelete: Cascade)
  characters  CharacterItem[]
  location    Location?       @relation(fields: [locationId], references: [id])
  plotEvents  PlotEventItem[]

  @@index([bookId])
}

model CharacterItem {
  characterId String
  itemId      String
  status      String
  acquiredAt  String?
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  item        Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([characterId, itemId])
}

model PlotEventItem {
  plotEventId String
  itemId      String
  role        String
  item        Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  plotEvent   PlotEvent @relation(fields: [plotEventId], references: [id], onDelete: Cascade)

  @@id([plotEventId, itemId])
}
